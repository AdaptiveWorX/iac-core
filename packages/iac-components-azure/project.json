{
  "name": "@adaptiveworx/iac-components-azure",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/iac-components-azure/src",
  "tags": ["scope:azure", "type:library", "publish:public"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/iac-components-azure",
        "command": "tsc -p tsconfig.lib.json"
      },
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run packages/iac-components-azure --reporter=verbose --passWithNoTests"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check packages/iac-components-azure"
      },
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/iac-components-azure",
        "command": "tsc --noEmit -p tsconfig.lib.json"
      },
      "cache": true
    }
  }
}
