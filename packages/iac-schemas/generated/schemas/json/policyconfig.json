{
  "$ref": "#/$defs/PolicyConfig",
  "$defs": {
    "PolicyConfig": {
      "type": "object",
      "properties": {
        "enableCostGuardrails": {
          "type": "boolean"
        },
        "enableSecurityPolicies": {
          "type": "boolean"
        },
        "enableCompliancePolicies": {
          "type": "boolean"
        },
        "maxMonthlyCostUsd": {
          "type": "number",
          "minimum": 100,
          "maximum": 1000000
        },
        "allowedRegions": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "us-east-1",
              "us-east-2",
              "us-west-1",
              "us-west-2",
              "eu-west-1",
              "eu-west-2",
              "eu-central-1",
              "ap-southeast-1",
              "ap-southeast-2",
              "ap-northeast-1",
              "use1",
              "use2",
              "usw1",
              "usw2",
              "euw1",
              "euw2",
              "euc1",
              "apse1",
              "apse2",
              "apne1"
            ]
          },
          "minItems": 1
        },
        "requiredTags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      },
      "required": [
        "enableCostGuardrails",
        "enableSecurityPolicies",
        "enableCompliancePolicies",
        "maxMonthlyCostUsd",
        "allowedRegions",
        "requiredTags"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.adaptiveworx.com/iac/policyconfig.json",
  "title": "PolicyConfig Schema",
  "description": "JSON Schema for PolicyConfig validation in agent-optimized IaC deployments",
  "x-agent-optimized": true,
  "x-version": "1.0.0",
  "x-namespace": "adaptiveworx.iac"
}