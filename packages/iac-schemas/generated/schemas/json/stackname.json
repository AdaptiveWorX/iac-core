{
  "$ref": "#/$defs/StackName",
  "$defs": {
    "StackName": {
      "type": "string",
      "minLength": 5,
      "errorMessage": {
        "minLength": "Stack name too short",
        "pattern": "Stack name must be kebab-case"
      },
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    }
  },
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.adaptiveworx.com/iac/stackname.json",
  "title": "StackName Schema",
  "description": "JSON Schema for StackName validation in agent-optimized IaC deployments",
  "x-agent-optimized": true,
  "x-version": "1.0.0",
  "x-namespace": "adaptiveworx.iac"
}