{
  "name": "@adaptiveworx/iac-schemas",
  "version": "0.1.2",
  "type": "module",
  "description": "Region aliases, canonical region names, and Zod-derived schema types for AdaptiveWorX™ infrastructure-as-code. Pure data + types — no runtime dependencies.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./regions": {
      "types": "./dist/index.d.ts",
      "default": "./config/regions.json"
    },
    "./generated/*": "./generated/*",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "config/regions.json",
    "generated",
    "LICENSE",
    "NOTICE",
    "README.md",
    "CHANGELOG.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdaptiveWorX/iac-core.git",
    "directory": "packages/iac-schemas"
  },
  "homepage": "https://github.com/AdaptiveWorX/iac-core/tree/main/packages/iac-schemas#readme",
  "bugs": {
    "url": "https://github.com/AdaptiveWorX/iac-core/issues"
  },
  "keywords": [
    "iac",
    "schemas",
    "regions",
    "aws",
    "azure",
    "gcp",
    "cloudflare",
    "multi-cloud",
    "typescript",
    "zod",
    "adaptiveworx"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "devDependencies": {
    "@types/node": "^24.0.0"
  }
}
