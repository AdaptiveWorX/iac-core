{
  "$schema": "./infisical-secrets.schema.json",
  "description": "Reference configuration for secrets stored in Infisical. Organized by folder path to match Infisical project structure. Sensitive values marked as '***'.",
  "project": {
    "id": "INFISICAL_PROJECT_ID",
    "name": "iac-worx",
    "organization": "adaptiveworx"
  },
  "folders": {
    "/": {
      "description": "Root-level organization secrets",
      "secrets": {
        "ORG_TENANT": {
          "description": "Tenant identifier (worx, care)",
          "values": { "dev": "worx", "stg": "worx", "prd": "worx", "sec": "worx" }
        },
        "ORG_NAME": {
          "description": "Organization name",
          "values": { "dev": "AdaptiveWorX", "stg": "AdaptiveWorX", "prd": "AdaptiveWorX", "sec": "AdaptiveWorX" }
        },
        "ORG_DOMAIN": {
          "description": "Organization domain",
          "values": { "dev": "adaptiveworx.com", "stg": "adaptiveworx.com", "prd": "adaptiveworx.com", "sec": "adaptiveworx.com" }
        },
        "PULUMI_ORG": {
          "description": "Pulumi Cloud organization",
          "values": { "dev": "adaptiveworx", "stg": "adaptiveworx", "prd": "adaptiveworx", "sec": "adaptiveworx" }
        }
      }
    },
    "/aws": {
      "description": "AWS-specific configuration and feature flags. Note: sec environment omits workload flags (VPC, storage, compute) as centralized VPCs fetch config from target environments via SecretManager context.",
      "secrets": {
        "VPC_CIDR_BASE": {
          "description": "Base CIDR block for VPC allocation in this environment",
          "values": { "dev": "10.224.0.0/11", "stg": "10.192.0.0/11", "prd": "10.0.0.0/9" }
        },
        "IAC_AWS_ACCOUNTS": {
          "description": "AWS account configuration (JSON)",
          "type": "json",
          "template": {
            "default": "app",
            "ops": { "id": "730335555486", "profile": "worx-ops-sec", "accountPurpose": "ops", "environmentClass": "operations", "ouName": "SecOps", "ouId": "ou-y21h-438hvrlm", "email": "aws-secops@adaptiveworx.com" },
            "app": { "id": "***", "profile": "worx-app-{env}", "accountPurpose": "app", "environmentClass": "development|staging|production", "ouName": "Pre-prod|Prod", "ouId": "***", "email": "worx-app-{env}@adaptiveworx.com" }
          },
          "values": {
            "dev": { "default": "app", "ops": { "id": "730335555486", "profile": "worx-ops-sec", "accountPurpose": "ops", "environmentClass": "operations", "ouName": "SecOps", "ouId": "ou-y21h-438hvrlm", "email": "aws-secops@adaptiveworx.com" }, "app": { "id": "413639306030", "profile": "worx-app-dev", "accountPurpose": "app", "environmentClass": "development", "ouName": "Pre-prod", "ouId": "ou-y21h-PLACEHOLDER", "email": "worx-app-dev@adaptiveworx.com" } },
            "stg": { "default": "app", "ops": { "id": "730335555486", "profile": "worx-ops-sec", "accountPurpose": "ops", "environmentClass": "operations", "ouName": "SecOps", "ouId": "ou-y21h-438hvrlm", "email": "aws-secops@adaptiveworx.com" }, "app": { "id": "335746353051", "profile": "worx-app-stg", "accountPurpose": "app", "environmentClass": "staging", "ouName": "Pre-prod", "ouId": "ou-y21h-PLACEHOLDER", "email": "worx-app-stg@adaptiveworx.com" } },
            "prd": { "default": "app", "ops": { "id": "730335555486", "profile": "worx-ops-sec", "accountPurpose": "ops", "environmentClass": "operations", "ouName": "SecOps", "ouId": "ou-y21h-438hvrlm", "email": "aws-secops@adaptiveworx.com" }, "app": { "id": "436083577402", "profile": "worx-app-prd", "accountPurpose": "app", "environmentClass": "production", "ouName": "Prod", "ouId": "ou-y21h-PLACEHOLDER", "email": "worx-app-prd@adaptiveworx.com" } },
            "sec": { "default": "ops", "ops": { "id": "730335555486", "profile": "worx-ops-sec", "accountPurpose": "ops", "environmentClass": "operations", "ouName": "SecOps", "ouId": "ou-y21h-438hvrlm", "email": "aws-secops@adaptiveworx.com" }, "app": { "dev": {...}, "stg": {...}, "prd": {...} } }
          }
        },
        "COST_OPTIMIZATION_ENABLED": {
          "description": "Enable cost optimization features",
          "values": { "dev": "true", "stg": "true", "prd": "false" }
        },
        "AUTO_SHUTDOWN_ENABLED": {
          "description": "Auto-shutdown non-production resources",
          "values": { "dev": "true", "stg": "false", "prd": "false" }
        },
        "MONITORING_ENABLED": {
          "description": "Enable CloudWatch monitoring (alarms, dashboards)",
          "values": { "dev": "false", "stg": "true", "prd": "true", "sec": "true" }
        },
        "FLOW_LOGS_ENABLED": {
          "description": "Enable VPC flow logs",
          "values": { "dev": "false", "stg": "true", "prd": "true" }
        },
        "FLOW_LOGS_TRAFFIC_TYPE": {
          "description": "VPC flow logs traffic type (ALL, ACCEPT, REJECT)",
          "values": {
            "dev": "ALL",
            "stg": "ALL",
            "prd": "ALL"
          }
        },
        "NAT_GATEWAY_COUNT": {
          "description": "Number of NAT gateways (0=IPv6 only)",
          "values": { "dev": "0", "stg": "1", "prd": "2" }
        },
        "VPC_ENDPOINTS": {
          "description": "Comma-separated list of VPC endpoints to create",
          "values": {
            "dev": "s3,dynamodb",
            "stg": "s3,dynamodb",
            "prd": "s3,dynamodb"
          }
        },
        "SUBNET_TIERS": {
          "description": "Subnet tier configuration (JSON array)",
          "type": "json",
          "template": [
            { "name": "public", "routeToInternet": true, "shareViaRam": false },
            { "name": "private", "routeToInternet": false, "shareViaRam": true },
            { "name": "data", "routeToInternet": false, "shareViaRam": true }
          ],
          "values": {
            "dev": "Default 3-tier (public/private/data)",
            "stg": "Default 3-tier (public/private/data)",
            "prd": "Default 3-tier (public/private/data)"
          }
        },
        "PROTECT_RESOURCES": {
          "description": "Protect critical resources (VPC, subnets) from accidental deletion",
          "values": { "dev": "false", "stg": "false", "prd": "true" }
        },
        "BACKUP_ENABLED": {
          "description": "Enable AWS Backup",
          "values": { "dev": "false", "stg": "true", "prd": "true" }
        },
        "RETENTION_DAYS": {
          "description": "Log retention in days",
          "values": { "dev": "30", "stg": "90", "prd": "365" }
        },
        "ENCRYPTION_REQUIRED": {
          "description": "Require encryption at rest",
          "values": { "dev": "true", "stg": "true", "prd": "true" }
        },
        "COMPLIANCE_REQUIRED": {
          "description": "Enable compliance controls",
          "values": { "dev": "false", "stg": "true", "prd": "true", "sec": "true" }
        },
        "GUARD_DUTY_ENABLED": {
          "description": "Enable AWS GuardDuty",
          "values": { "dev": "false", "stg": "true", "prd": "true", "sec": "true" }
        },
        "AUDIT_LOGGING_ENABLED": {
          "description": "Enable audit logging",
          "values": { "dev": "false", "stg": "true", "prd": "true", "sec": "true" }
        },
        "SECURITY_MONITORING_ENABLED": {
          "description": "Enable security monitoring",
          "values": { "dev": "false", "stg": "true", "prd": "true", "sec": "true" }
        }
      }
    },
    "/github": {
      "description": "GitHub integration configuration",
      "secrets": {
        "GITHUB_ORG": {
          "description": "GitHub organization name",
          "values": { "dev": "AdaptiveWorX", "stg": "AdaptiveWorX", "prd": "AdaptiveWorX", "sec": "AdaptiveWorX" }
        },
        "GITHUB_ALLOWED_REPOS": {
          "description": "Comma-separated list of repos allowed to deploy via OIDC",
          "values": { "dev": "AdaptiveWorX/iac-worx,AdaptiveWorX/iac-components", "stg": "AdaptiveWorX/iac-worx,AdaptiveWorX/iac-components", "prd": "AdaptiveWorX/iac-worx,AdaptiveWorX/iac-components", "sec": "AdaptiveWorX/iac-worx,AdaptiveWorX/iac-components" }
        }
      }
    },
    "/cloudflare": {
      "description": "Cloudflare DNS and CDN configuration",
      "secrets": {
        "CLOUDFLARE_ACCOUNT_ID": {
          "description": "Cloudflare account ID (public)",
          "values": { "dev": "f23ad949750ddaf360446a334bffdc3d", "stg": "f23ad949750ddaf360446a334bffdc3d", "prd": "f23ad949750ddaf360446a334bffdc3d", "sec": "f23ad949750ddaf360446a334bffdc3d" }
        },
        "CLOUDFLARE_API_TOKEN": {
          "description": "Cloudflare API token for DNS management",
          "sensitive": true,
          "values": { "dev": "***", "stg": "***", "prd": "***", "sec": "***" }
        },
        "CLOUDFLARE_ZONES": {
          "description": "Map of domain names to zone IDs (JSON)",
          "type": "json",
          "template": { "adaptiveworx.com": "c04fb51743857b29d019e26998e0785f", "adaptiveworx.net": "", "adaptiveworx.org": "" },
          "values": { "dev": "Same across all envs", "stg": "Same across all envs", "prd": "Same across all envs", "sec": "Same across all envs" }
        }
      }
    },
    "/quality": {
      "description": "Code quality thresholds enforced via scripts/quality-thresholds.ts. These prevent agents/developers from silently lowering quality standards. Same across all environments.",
      "secrets": {
        "TYPE_COVERAGE_MIN": {
          "description": "Minimum TypeScript type coverage percentage (strict mode)",
          "values": { "dev": "98.5", "stg": "98.5", "prd": "98.5", "sec": "98.5" }
        },
        "BIOME_MAX_DIAGNOSTICS": {
          "description": "Maximum Biome diagnostics allowed (0 = zero-tolerance policy)",
          "values": { "dev": "0", "stg": "0", "prd": "0", "sec": "0" }
        },
        "TEST_COVERAGE_MIN": {
          "description": "Minimum test coverage percentage (future enforcement)",
          "values": { "dev": "80", "stg": "80", "prd": "80", "sec": "80" }
        },
        "BUILD_WARNINGS_ALLOWED": {
          "description": "Whether build warnings are tolerated (false = fail on warnings)",
          "values": { "dev": "false", "stg": "false", "prd": "false", "sec": "false" }
        }
      }
    }
  }
}
