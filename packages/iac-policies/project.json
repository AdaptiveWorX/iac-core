{
  "name": "@adaptiveworx/iac-policies",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "library",
  "sourceRoot": "packages/iac-policies/src",
  "tags": ["scope:policies", "type:library", "publish:public"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/iac-policies",
        "command": "tsc -p tsconfig.lib.json"
      },
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["^build"],
      "cache": true
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run packages/iac-policies --reporter=verbose"
      },
      "cache": true
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run 'packages/iac-policies/**/*.unit.test.ts' --reporter=verbose"
      },
      "cache": true
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "biome check packages/iac-policies/src"
      },
      "cache": true
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "packages/iac-policies",
        "command": "tsc --noEmit -p tsconfig.lib.json"
      },
      "dependsOn": ["^build"],
      "cache": true
    }
  }
}
