{
  "name": "@adaptiveworx/flux-core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "AdaptiveWorX Flux — open-source Pulumi infrastructure libraries for multi-cloud IaC.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdaptiveWorX/flux-core.git"
  },
  "bugs": {
    "url": "https://github.com/AdaptiveWorX/flux-core/issues"
  },
  "homepage": "https://github.com/AdaptiveWorX/flux-core#readme",
  "scripts": {
    "nx": "nx",
    "build": "nx run-many -t build",
    "build:affected": "nx affected -t build",
    "test": "nx run-many -t test",
    "test:affected": "nx affected -t test",
    "lint": "nx run-many -t lint",
    "lint:affected": "nx affected -t lint",
    "typecheck": "nx run-many -t typecheck",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "graph": "nx graph",
    "affected": "nx affected",
    "clean": "nx reset && rm -rf node_modules/.cache .nx/cache packages/*/dist",
    "release": "nx release",
    "release:dry": "nx release --dry-run",
    "release:publish": "nx release publish",
    "compliance:report": "tsx scripts/compliance-report.ts"
  },
  "keywords": [
    "pulumi",
    "iac",
    "infrastructure-as-code",
    "aws",
    "azure",
    "multi-cloud",
    "typescript",
    "adaptiveworx"
  ],
  "author": "Adaptive Intelligence, LLC",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.26.2",
  "devDependencies": {
    "@biomejs/biome": "2.2.5",
    "@nx/devkit": "^22.5.1",
    "@nx/js": "^22.5.1",
    "@tsconfig/strictest": "^2.0.6",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "nx": "^22.5.1",
    "tsx": "^4.20.6",
    "typescript": "^6.0.0",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^3.2.4"
  }
}
